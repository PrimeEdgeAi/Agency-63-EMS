      "typeVersion": 1
    },
    {
      "parameters": {
        "functionCode": "const jwt = require('jsonwebtoken');\nconst SECRET = \"your_super_secret_key\";\n\nconst data = this.getWorkflowStaticData('global');\nconst record = data[$json.email];\n\nif (!record) return [{ json:{ success:false, message:\"No OTP\" }}];\nif (Date.now() > record.expires) return [{ json:{ success:false, message:\"Expired\" }}];\nif (record.otp != $json.otp) return [{ json:{ success:false, message:\"Invalid\" }}];\n\nconst token = jwt.sign({ email:$json.email, role:record.role }, SECRET, { expiresIn:\"1h\" });\n\nlet redirect = \"/agent.html\";\nif (record.role === \"admin\") redirect = \"/admin.html\";\nif (record.role === \"super_admin\") redirect = \"/superadmin.html\";\n\nreturn [{ json:{ success:true, token, role:record.role, redirect }}];"
      },
