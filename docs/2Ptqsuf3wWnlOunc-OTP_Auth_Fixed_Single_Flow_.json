      "parameters": {
        "functionCode": "const data = this.getWorkflowStaticData('global');\ndata[$json.email] = { otp:$json.otp, role:$json.role, expires:Date.now()+5*60*1000 };\nreturn items;"
      },
      "id": "6ec57928-ba3a-488b-9737-9782ac4c4f72",
      "name": "Store OTP",
      "type": "n8n-nodes-base.function",
