      "parameters": {
        "functionCode": "const inputEmail = $node[\"Webhook\"].json[\"email\"];\nconst rows = items.map(i => i.json);\nconst match = rows.find(r => r.email && r.email.toLowerCase() === inputEmail.toLowerCase());\nif (!match) return [{ json: { found:false } }];\nreturn [{ json: { found:true, email:match.email, role:match.role } }];"
